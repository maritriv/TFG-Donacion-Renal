<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootResult"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige">

    <!-- CÍRCULO PRINCIPAL -->
    <FrameLayout
        android:id="@+id/circleContainer"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_outer"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/checkIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_inner"
            android:padding="24dp"
            android:src="@drawable/ic_check"/>
    </FrameLayout>

    <!-- TEXTO PRINCIPAL -->
    <TextView
        android:id="@+id/textStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DONANTE VÁLIDO"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/dark_blue"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/circleContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTÓN VOLVER -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonBackToMenu"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="40dp"
        android:text="VOLVER AL MENÚ PRINCIPAL"
        android:textAllCaps="false"
        android:textColor="@color/dark_blue"
        android:textSize="16sp"
        app:strokeColor="@color/dark_blue"
        app:strokeWidth="1dp"
        app:cornerRadius="50dp"
        app:backgroundTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/textStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="32dp"/>

    <!-- BOTÓN PDF -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/downloadPDF"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:text="DESCARGAR PDF"
        android:textAllCaps="false"
        android:textColor="@color/dark_blue"
        android:textSize="16sp"
        app:strokeColor="@color/dark_blue"
        app:strokeWidth="1dp"
        app:cornerRadius="50dp"
        app:backgroundTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/buttonBackToMenu"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>