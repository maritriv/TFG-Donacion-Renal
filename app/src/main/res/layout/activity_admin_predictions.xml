<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <!-- Fila VOLVER -->
    <LinearLayout
        android:id="@+id/backRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:paddingBottom="8dp"
        android:layout_marginStart="16dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="@string/desc_back"
            app:tint="@color/dark_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/volver"
            android:textColor="@color/dark_blue"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Toolbar azul -->
    <LinearLayout
        android:id="@+id/profileToolbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@color/dark_blue"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/backRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/historial_predicciones"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- CONTENIDO PRINCIPAL -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@+id/profileToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TARJETA DE PREDICCIONES -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPredictions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Título -->
                <TextView
                    android:id="@+id/tvPredTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/predicciones"
                    android:textColor="@color/dark_blue"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <!-- FILA: Mostrando X filas / Filtrar / Exportar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvShowingRows"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/grey"
                        android:textSize="12sp"
                        tools:text="@string/mostrando_0_filas" />

                    <TextView
                        android:id="@+id/btnFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="@string/filtrar"
                        android:layout_marginEnd="8dp"
                        android:textColor="@color/dark_blue"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/btnExport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="@string/exportar"
                        android:textColor="@color/dark_blue"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- TABLA -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="horizontal">

                    <ScrollView
                        android:id="@+id/scrollPredictions"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:fillViewport="true">

                        <TableLayout
                            android:id="@+id/tablePredictions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:stretchColumns="*">

                            <TableRow
                                android:background="#F0F0F0"
                                android:padding="6dp">

                                <TextView android:text="@string/header_numero"          android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_edad"            android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_sexo"            android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_capnometria"     android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_causa_cardiaca" android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_cardiocomp"     android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_rec_pulso"      android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_momento"        android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_resultado"      android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_informe"        android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                            </TableRow>

                        </TableLayout>
                    </ScrollView>
                </HorizontalScrollView>

                <!-- No hay datos -->
                <TextView
                    android:id="@+id/tvNoPredictions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/no_hay_predicciones"
                    android:textColor="@color/grey"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>