<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige">

    <!-- TARJETA BLANCA GRANDE -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_import"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/title_import"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/importar_predicciones"
                android:textAlignment="center"
                android:textColor="@color/dark_blue"
                android:fontFamily="sans-serif-medium"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- CAMPO SELECCIÓN CSV (clicable) -->
            <LinearLayout
                android:id="@+id/filePickerArea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_searchbox"
                android:clickable="true"
                android:focusable="true">

                <!-- Nombre del archivo -->
                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/selecciona_csv"
                    android:textColor="@color/grey"
                    android:textSize="15sp"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <!-- Botón X para limpiar -->
                <ImageButton
                    android:id="@+id/btnClearFile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/quitar_archivo"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:padding="2dp"
                    android:visibility="gone"
                    app:tint="@color/dark_blue" />
            </LinearLayout>

            <!-- Barra de progreso (debajo del buscador) -->
            <ProgressBar
                android:id="@+id/barraProgreso"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/barraprogreso"
                android:visibility="gone" />

            <!-- BOTÓN AÑADIR (solo visible cuando haya archivo) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddPredictions"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="@string/añadir_filas"
                android:textAllCaps="false"
                android:textColor="@color/dark_blue"
                android:textSize="16sp"
                app:strokeColor="@color/dark_blue"
                app:strokeWidth="2dp"
                android:visibility="gone"
                app:backgroundTint="@color/white"
                app:cornerRadius="50dp" />

            <!-- BOTÓN AYUDA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHelp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="@string/ayuda_formato_csv"
                android:textAllCaps="false"
                android:textColor="@color/dark_blue"
                android:textSize="16sp"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/dark_blue"
                app:strokeWidth="2dp"
                app:cornerRadius="50dp" />

            <!-- BOTÓN VOLVER -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_volver"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="@string/volver_mayus"
                android:textAllCaps="false"
                android:textColor="@color/beige"
                android:textSize="16sp"
                app:backgroundTint="@color/dark_blue"
                app:cornerRadius="50dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>