<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ABD0E0">

    <!-- Título -->
    <TextView
        android:id="@+id/title_import"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="IMPORTAR PREDICCIONES"
        android:textColor="#042939"
        android:textStyle="bold"
        android:textSize="28sp"
        android:fontFamily="sans-serif-condensed-medium"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_goneMarginTop="16dp"
        android:layout_marginTop="24dp"/>

    <!-- Caja azul principal -->
    <LinearLayout
        android:id="@+id/boxMain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/loginbox"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/title_import"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp">

        <!-- Área “Selecciona un archivo CSV …” (clicable) -->
        <FrameLayout
            android:id="@+id/filePickerArea"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/rounded_input_blue"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="Selecciona un archivo CSV…"
                android:textColor="#0b2e3e"
                android:textSize="15sp"
                android:paddingEnd="40dp"/>

            <!-- Botón X para deseleccionar archivo -->
            <ImageButton
                android:id="@+id/btnClearFile"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="end|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="Quitar archivo"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#0b2e3e"
                android:visibility="gone"/>

            <!-- Barra de progreso (solo visible durante importación) -->
            <ProgressBar
                android:id="@+id/barraProgreso"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_gravity="bottom"
                android:layout_marginBottom="6dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/barraprogreso"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- Botón grande: Añadir (aparece cuando hay archivo) -->
        <Button
            android:id="@+id/btnAddPredictions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="AÑADIR A LAS PREDICCIONES ACTUALES"
            android:backgroundTint="#fcfe82"
            android:textColor="@color/material_dynamic_primary10"
            android:visibility="gone"/>

        <!-- Fila de botones: Ayuda + Volver -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnHelp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AYUDA FORMATO CSV"
                android:backgroundTint="#fcfe82"
                android:textColor="@color/material_dynamic_primary10"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="0dp"/>

            <Button
                android:id="@+id/btn_volver"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VOLVER"
                android:backgroundTint="#fcfe82"
                android:textColor="@color/material_dynamic_primary10"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
