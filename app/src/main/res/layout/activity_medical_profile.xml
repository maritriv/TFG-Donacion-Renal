<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    tools:ignore="TooDeepLayout">

    <!-- Fila VOLVER (flecha + texto) -->
    <LinearLayout
        android:id="@+id/backRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:paddingBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="@string/desc_back"
            app:tint="@color/dark_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/volver"
            android:textColor="@color/dark_blue"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Barra azul tipo toolbar -->
    <LinearLayout
        android:id="@+id/profileToolbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@color/dark_blue"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/backRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/perfil_del_usuario"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Contenido fijo -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/profileToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TARJETA PERFIL -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUserProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_person_24"
                    android:background="@drawable/circle_white"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:contentDescription="@string/desc_icon_person"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Contenedor acciones (X + lápiz) -->
                <LinearLayout
                    android:id="@+id/actionsRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Estado -->
                    <TextView
                        android:id="@+id/tvUserStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="@string/estado_activo"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:background="@drawable/bg_status_active" />

                    <!-- X (solo edición, para salir del modo edición) -->
                    <ImageView
                        android:id="@+id/btnDeleteUser"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_cross"
                        android:contentDescription="@string/cancelar"
                        android:visibility="gone"
                        app:tint="@color/dark_blue" />

                    <!-- Lápiz -->
                    <ImageView
                        android:id="@+id/btnEditUser"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_edit_24"
                        android:contentDescription="@string/editar"
                        app:tint="@color/dark_blue" />
                </LinearLayout>

                <!-- Rol + estado -->
                <LinearLayout
                    android:id="@+id/rowRoleStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="12dp"
                    app:layout_constraintTop_toTopOf="@id/imgAvatar"
                    app:layout_constraintStart_toEndOf="@id/imgAvatar"
                    app:layout_constraintEnd_toStartOf="@id/actionsRow"
                    app:layout_constraintHorizontal_bias="0.0">

                    <!-- Rol (lectura) -->
                    <TextView
                        android:id="@+id/tvUserRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dark_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="@string/medico" />

                    <!-- Spinner de rol (edición) -->
                    <Spinner
                        android:id="@+id/spinnerRole"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/spinner_bg"
                        android:popupBackground="@drawable/spinner_bg"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingVertical="8dp"
                        android:visibility="gone"/>
                    <!-- Separador pequeño -->
                    <View
                        android:layout_width="8dp"
                        android:layout_height="0dp" />

                </LinearLayout>

                <!-- Nombre -->
                <EditText
                    android:id="@+id/etName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:enabled="false"
                    android:hint="@string/hint_nombre"
                    android:inputType="textPersonName"
                    android:autofillHints="name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/rowRoleStatus"
                    app:layout_constraintStart_toEndOf="@id/imgAvatar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0" />

                <!-- Apellidos -->
                <EditText
                    android:id="@+id/etLastname"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:enabled="false"
                    android:hint="@string/hint_apellidos"
                    android:inputType="textPersonName"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/etName"
                    app:layout_constraintStart_toEndOf="@id/imgAvatar"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Email -->
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:enabled="false"
                    android:hint="@string/hint_email"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress"
                    android:textSize="14sp"
                    android:textColor="@color/grey"
                    app:layout_constraintTop_toBottomOf="@id/etLastname"
                    app:layout_constraintStart_toEndOf="@id/imgAvatar"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Fecha nacimiento -->
                <EditText
                    android:id="@+id/etBirthdate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:clickable="false"
                    android:focusable="false"
                    android:enabled="false"
                    android:hint="@string/hint_fecha_nacimiento"
                    android:inputType="date"
                    android:autofillHints="birthday"
                    android:textSize="14sp"
                    android:textColor="@color/grey"
                    app:layout_constraintTop_toBottomOf="@id/etEmail"
                    app:layout_constraintStart_toEndOf="@id/imgAvatar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón REALIZAR CAMBIOS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveChanges"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/realizar_cambios"
            android:textAllCaps="false"
            android:textColor="@color/dark_blue"
            android:visibility="gone"
            app:backgroundTint="@color/white"
            app:strokeColor="@color/dark_blue"
            app:strokeWidth="1dp"
            app:cornerRadius="50dp" />

        <!-- Botón ELIMINAR USUARIO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelChanges"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="@string/eliminar_usuario"
            android:textAllCaps="false"
            android:textColor="@color/dark_blue"
            android:visibility="gone"
            app:backgroundTint="@color/white"
            app:strokeColor="@color/dark_blue"
            app:strokeWidth="1dp"
            app:cornerRadius="50dp" />

        <!-- TARJETA PREDICCIONES -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPredictions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Línea 1: Título "PREDICCIONES" -->
                <TextView
                    android:id="@+id/tvPredTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/predicciones"
                    android:textColor="@color/dark_blue"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <!-- Línea 2: "Mostrando X filas   Filtrar   Exportar" -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <!-- Mostrando X filas -->
                    <TextView
                        android:id="@+id/tvShowingRows"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/grey"
                        android:textSize="12sp"
                        tools:text="@string/mostrando_0_filas" />

                    <!-- Botón Filtrar -->
                    <TextView
                        android:id="@+id/btnFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="@string/filtrar"
                        android:textSize="12sp"
                        android:textColor="@color/dark_blue"/>

                    <!-- Botón Exportar -->
                    <TextView
                        android:id="@+id/btnExport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="@string/exportar"
                        android:textSize="12sp"
                        android:textColor="@color/dark_blue"/>
                </LinearLayout>

                <!-- Tabla de predicciones con scroll horizontal + vertical -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="horizontal">

                    <ScrollView
                        android:id="@+id/scrollPredictions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fillViewport="true"
                        tools:ignore="NestedScrolling">

                        <TableLayout
                            android:id="@+id/tablePredictions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:stretchColumns="*">

                            <TableRow
                                android:background="#F0F0F0"
                                android:padding="6dp">

                                <TextView android:text="@string/header_numero"          android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_edad"            android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_sexo"            android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_capnometria"     android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_causa_cardiaca" android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_cardiocomp"     android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_rec_pulso"      android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_momento"        android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_resultado"      android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                                <TextView android:text="@string/header_informe"        android:padding="8dp" android:textStyle="bold" android:textSize="12sp"/>
                            </TableRow>

                            <!-- Filas desde código -->
                        </TableLayout>
                    </ScrollView>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvNoPredictions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/no_hay_predicciones"
                    android:textColor="@color/grey"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>