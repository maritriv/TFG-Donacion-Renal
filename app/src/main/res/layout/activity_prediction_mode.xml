<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <!-- TARJETA BLANCA CENTRAL -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="24dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿EN QUÉ PUNTO QUIERES REALIZAR LA PREDICCIÓN?"
                android:textAlignment="center"
                android:textColor="@color/dark_blue"
                android:fontFamily="sans-serif-medium"
                android:textSize="20sp"
                android:layout_marginBottom="24dp"
                android:textStyle="bold"
                android:lineSpacingExtra="3dp" />

            <!-- BOTÓN: ANTES -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBefore"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:text="ANTES DE LA RCP"
                android:textColor="@color/dark_blue"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/dark_blue"
                app:strokeWidth="1dp"
                app:cornerRadius="50dp" />

            <!-- BOTÓN: A LOS 20 MINUTOS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginBottom="16dp"
                android:text="A LOS 20 MIN DE LA RCP"
                android:textColor="@color/dark_blue"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/dark_blue"
                app:strokeWidth="1dp"
                app:cornerRadius="50dp" />

            <!-- BOTÓN: DESPUÉS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAfter"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="26dp"
                android:text="DESPUÉS DE LA RCP"
                android:textColor="@color/dark_blue"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/dark_blue"
                app:strokeWidth="1dp"
                app:cornerRadius="50dp" />

            <!-- BOTÓN VOLVER -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToMain"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="26dp"
                android:text="VOLVER"
                android:textColor="@color/beige"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/dark_blue"
                app:strokeColor="@color/beige"
                app:strokeWidth="1dp"
                app:cornerRadius="50dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>