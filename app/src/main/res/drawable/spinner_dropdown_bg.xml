<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Fondo de la tarjeta -->
    <solid android:color="#FFFFFF" />

    <!-- Borde suave -->
    <stroke
        android:width="1dp"
        android:color="#D0D7E2" />

    <!-- Esquinas redondeadas -->
    <corners android:radius="12dp" />

    <!-- Pequeño padding interior para que el texto no pegue al borde -->
    <padding
        android:left="4dp"
        android:right="4dp"
        android:top="4dp"
        android:bottom="4dp" />
</shape>