<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_form"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="14dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/scroll_form"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/panel_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:paddingEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/btnBackForm"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_back_24"
                        android:contentDescription="@string/volver"
                        app:tint="@color/dark_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/volver"
                        android:textColor="@color/dark_blue"
                        android:textSize="16sp"
                        android:paddingStart="6dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_form_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/formulario"
                    android:textColor="@color/dark_blue"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <!-- EDAD -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_edad"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/edad"
                    app:boxStrokeWidth="0dp"
                    app:boxBackgroundMode="filled"
                    android:visibility="visible">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_edad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:inputType="number"
                        android:contentDescription="@string/edad" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- SEXO (AFTER: VISIBLE como el antiguo) -->
                <TextView
                    android:id="@+id/tv_sexo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/sexo"
                    android:textColor="@color/dark_blue"
                    android:textSize="16sp"
                    android:visibility="visible" />

                <RelativeLayout
                    android:id="@+id/container_sexo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible">

                    <Spinner
                        android:id="@+id/sp_sexo_femenino"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/camposform"
                        android:popupBackground="@drawable/camposform" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/arrow_down_ic"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/desplegar" />
                </RelativeLayout>

                <!-- CAPNOMETRÍA -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_capnometria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/capnometria"
                    app:boxStrokeWidth="0dp"
                    app:boxBackgroundMode="filled"
                    android:visibility="visible">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_capnometria"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:inputType="number"
                        android:contentDescription="@string/capnometria" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- COLESTEROL (AFTER: OCULTO) -->
                <TextView
                    android:id="@+id/tv_colesterol"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/colesterol_pregunta"
                    android:textColor="@color/dark_blue"
                    android:textSize="16sp"
                    android:visibility="gone"/>

                <RelativeLayout
                    android:id="@+id/container_colesterol"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">

                    <Spinner
                        android:id="@+id/sp_colesterol"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:popupBackground="@drawable/camposform" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/arrow_down_ic"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/desplegar" />
                </RelativeLayout>

                <!-- ADRENALINA (solo MID) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_adrenalina"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:hint="@string/adrenalina_dosis"
                    app:boxStrokeWidth="0dp"
                    app:boxBackgroundMode="filled"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_adrenalina_n"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:inputType="number"
                        android:contentDescription="@string/adrenalina_dosis" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- IMC (solo MID) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_imc"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:hint="@string/imc"
                    app:boxStrokeWidth="0dp"
                    app:boxBackgroundMode="filled"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_imc"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:inputType="numberDecimal"
                        android:contentDescription="@string/imc" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- CAUSA CARDIACA (AFTER: VISIBLE) -->
                <TextView
                    android:id="@+id/tv_causa_cardiaca"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/causa_cardiaca_pregunta"
                    android:textColor="@color/dark_blue"
                    android:textSize="16sp"
                    android:visibility="visible" />

                <RelativeLayout
                    android:id="@+id/container_causa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible">

                    <Spinner
                        android:id="@+id/sp_causa_cardiaca"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:popupBackground="@drawable/camposform" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/arrow_down_ic"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/desplegar" />
                </RelativeLayout>

                <!-- CARDIOCOMPRESIÓN (AFTER: VISIBLE) -->
                <TextView
                    android:id="@+id/tv_cardio_manual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/cardiocompresion_pregunta"
                    android:textColor="@color/dark_blue"
                    android:textSize="16sp"
                    android:visibility="visible" />

                <RelativeLayout
                    android:id="@+id/container_cardio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible">

                    <Spinner
                        android:id="@+id/sp_cardio_manual"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:popupBackground="@drawable/camposform" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/arrow_down_ic"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/desplegar" />
                </RelativeLayout>

                <!-- RECUPERACIÓN (AFTER: VISIBLE) -->
                <TextView
                    android:id="@+id/tv_recuperacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/recuperacion_pregunta"
                    android:textColor="@color/dark_blue"
                    android:textSize="16sp"
                    android:visibility="visible" />

                <RelativeLayout
                    android:id="@+id/container_recuperacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible">

                    <Spinner
                        android:id="@+id/sp_recuperacion"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/camposform"
                        android:popupBackground="@drawable/camposform" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/arrow_down_ic"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/desplegar" />
                </RelativeLayout>

                <!-- BOTÓN -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_predic"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/realizar_prediccion"
                    android:textColor="@color/beige"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/dark_blue"
                    app:cornerRadius="50dp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>