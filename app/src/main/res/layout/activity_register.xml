<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mid_blue">

    <!-- Panel blanco que baja hasta el fondo -->
    <LinearLayout
        android:id="@+id/panel_register"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_panel_full_rounded"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Fila “Volver” (icono + texto) -->
        <LinearLayout
            android:id="@+id/backRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back_24"
                android:contentDescription="@string/navigation_drawer_close"
                app:tint="@color/dark_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Volver"
                android:textColor="@color/dark_blue"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Título -->
        <TextView
            android:id="@+id/tvTitleRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registro"
            android:textColor="@color/dark_blue"
            android:textSize="40sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Nombre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_person_24"
                app:tint="@color/dark_blue" />

            <EditText
                android:id="@+id/name"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Nombre"
                android:textColor="@color/dark_blue"
                android:textColorHint="@color/dark_blue"
                android:background="@android:color/transparent"
                android:textCursorDrawable="@drawable/custom_cursor"/>
        </LinearLayout>

        <!-- Apellidos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_person_24"
                app:tint="@color/dark_blue" />

            <EditText
                android:id="@+id/lastname"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Apellidos"
                android:textColor="@color/dark_blue"
                android:textColorHint="@color/dark_blue"
                android:background="@android:color/transparent"
                android:textCursorDrawable="@drawable/custom_cursor"/>
        </LinearLayout>

        <!-- Fecha de nacimiento -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_calendar_24"
                app:tint="@color/dark_blue" />

            <EditText
                android:id="@+id/birthdate"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Fecha de Nacimiento"
                android:clickable="true"
                android:focusable="false"
                android:textColor="@color/dark_blue"
                android:textColorHint="@color/dark_blue"
                android:background="@android:color/transparent"
                android:textCursorDrawable="@drawable/custom_cursor"/>
        </LinearLayout>

        <!-- Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_email_24"
                app:tint="@color/dark_blue" />

            <EditText
                android:id="@+id/email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Correo Electrónico"
                android:inputType="textEmailAddress"
                android:textColor="@color/dark_blue"
                android:textColorHint="@color/dark_blue"
                android:background="@android:color/transparent"
                android:textCursorDrawable="@drawable/custom_cursor"/>
        </LinearLayout>

        <!-- Contraseña -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock_24"
                app:tint="@color/dark_blue" />

            <EditText
                android:id="@+id/password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:textColor="@color/dark_blue"
                android:textColorHint="@color/dark_blue"
                android:background="@android:color/transparent"
                android:textCursorDrawable="@drawable/custom_cursor"/>
        </LinearLayout>

        <!-- Confirmar contraseña -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock_24"
                app:tint="@color/dark_blue" />

            <EditText
                android:id="@+id/confirm_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Confirmar Contraseña"
                android:inputType="textPassword"
                android:textColor="@color/dark_blue"
                android:textColorHint="@color/dark_blue"
                android:background="@android:color/transparent"
                android:textCursorDrawable="@drawable/custom_cursor"/>
        </LinearLayout>

        <!-- Selector de rol -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Selecciona tu rol"
            android:textStyle="bold"
            android:textColor="@color/dark_blue"
            android:textSize="16sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_drop_down_24"
                android:rotation="180"
                app:tint="@color/dark_blue" />

            <Spinner
                android:id="@+id/role_spinner"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:spinnerMode="dropdown"
                android:background="@android:color/transparent"/>
        </LinearLayout>

        <!-- Botón Registrarse -->
        <Button
            android:id="@+id/register_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="Registrarse"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/beige"
            android:background="@drawable/bg_button_primary"/>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>