<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ÚNICO TEMA PRINCIPAL -->
    <style name="Theme.RenalDCD" parent="Theme.Material3.Light.NoActionBar">

        <!-- Colores principales de tu app -->
        <item name="colorPrimary">@color/dark_blue</item>
        <item name="colorPrimaryContainer">@color/dark_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/dark_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Fondo de pantallas -->
        <item name="android:windowBackground">@color/beige</item>

        <!-- 🔹 Status bar (hora/batería arriba) -->
        <item name="android:statusBarColor">@color/white</item>

        <!-- Iconos claros en la status bar -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- No usar action bar antigua -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <item name="materialAlertDialogTheme">@style/CustomAlertDialog</item>

    </style>

    <!-- Dialogos redondeados Material3 -->
    <style name="CustomAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/CustomDialogShape</item>
    </style>

    <style name="CustomDialogShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>


    <!-- Tema SOLO PARA SPLASH -->
    <style name="Theme.RenalDCD.Splash" parent="Theme.RenalDCD">
        <item name="android:windowBackground">@color/dark_blue</item>
    </style>

</resources>