<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige"
    android:padding="16dp">

    <!-- Fila VOLVER (flecha + texto) -->
    <LinearLayout
        android:id="@+id/backRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:paddingBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="@string/desc_back"
            app:tint="@color/dark_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/volver"
            android:textColor="@color/dark_blue"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- SWITCH grande: Médicos / Administradores -->
    <LinearLayout
        android:id="@+id/userTypeSwitch"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_user_type_switch"
        android:padding="3dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/backRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Opción: MÉDICOS -->
        <TextView
            android:id="@+id/tvSwitchMedicos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/medicos_mayus"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_switch_left_selectable"
            android:textColor="@color/user_type_switch_text"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Opción: ADMINISTRADORES -->
        <TextView
            android:id="@+id/tvSwitchAdmins"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/administradores_mayus"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_switch_right_selectable"
            android:textColor="@color/user_type_switch_text"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Título grande CENTRADO -->
    <TextView
        android:id="@+id/tvUsersTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/medicos_mayus"
        android:textColor="@color/dark_blue"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/userTypeSwitch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buscador -->
    <EditText
        android:id="@+id/searchInput"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:hint="@string/buscar_usuario_hint"
        android:background="@drawable/bg_searchbox"
        android:textColor="@color/grey"
        android:textColorHint="@color/grey"
        android:textSize="16sp"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tvUsersTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lista de usuarios -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUsers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/searchInput"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>